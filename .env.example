# Copy to .env and adjust as needed.

# Host port for the browser UI
UI_PORT=4040

# Host paths for data volumes
INCOMING_DIR=./data/incoming
PROCESSED_DIR=./data/processed
ARCHIVE_DIR=./data/archive

# INI config file on the host
CONFIG_FILE=./data/color_palette_config.ini

# Optional: rclone config for Drive uploads (leave blank to disable/make unavailable)
RCLONE_CONFIG=./data/rclone.conf

# Telegram bot token (for palette_telegram_bot)
TELEGRAM_BOT_TOKEN=

# Bot data dir (state)
BOT_DATA_DIR=./data/bot
